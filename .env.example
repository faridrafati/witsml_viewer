# ════════════════════════════════════════════════════════════════════════
#  WITSML Mudlogging Monitor — environment template
#  Copy to `.env` (`cp .env.example .env`) and adjust. `.env` is gitignored.
#  Every setting here maps 1:1 to backend/app/config.py (Settings). Nothing
#  is hard-coded in source — this file is the single source of truth.
# ════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ─────────────────────────────────────────────────────────────
# Postgres is the compose default. SQLite is the zero-config dev fallback.
DATABASE_URL=postgresql+asyncpg://witsml:witsml@postgres:5432/witsml
# SQLite fallback (uncomment, comment the line above):
# DATABASE_URL=sqlite+aiosqlite:///./witsml.db

# ── Redis (optional) ─────────────────────────────────────────────────────
# Warm ring-buffer + WS pub/sub. Leave blank to use the in-process fallback.
REDIS_URL=redis://redis:6379/0

# ── WITSML test server (mockstore in compose) ────────────────────────────
# Endpoint is the SOAP Store service. GetVersion is the connectivity smoke
# test; it must return a string containing "1.4.1.1". In `docker compose up`
# this resolves to the in-house mockstore container (mockstore/).
WITSML_URL=http://mockstore:7070/witsml/store
WITSML_USERNAME=witsml
WITSML_PASSWORD=witsml
WITSML_VERIFY_SSL=true          # set false only for self-signed test certs
# Optional: path to a bundled WMLS.WSDL. If unset, the client loads the WSDL
# from `${WITSML_URL}?wsdl` at runtime.
WITSML_WSDL_PATH=

# ── Ingestion engine ─────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=5         # one coordinated tick
INGEST_CONCURRENCY=5            # bounded in-flight wells (4–6 recommended)
INGEST_STAGGER_MS=250           # spread 20 wells across the 5 s window
RING_BUFFER_HOURS=6             # warm cache depth per well
MAX_RETURN_NODES=1000           # OptionsIn maxReturnNodes for data polls
SIMULATED_WELL_COUNT=20         # how many wells the simulator creates

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-minimum-32-bytes-long
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=720
# Fernet key encrypting WITSML credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ── Bootstrap super-admin (seed) ─────────────────────────────────────────
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=admin

# ── Frontend (Vite reads these at build/dev time) ────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000
